# Anthropic API key — required
ANTHROPIC_API_KEY=sk-ant-...

# Runtime mode: interactive | mcp | task (default: interactive)
MODE=interactive

# For MODE=task: the task string to run
# TASK="Find the top 5 affiliate programs in the personal finance niche"

# Port for the MCP HTTP server (default: 3001)
MCP_PORT=3001

# Node environment
NODE_ENV=development
